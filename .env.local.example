# --- Supabase (client portal) ---
# Publishable key: safe to expose to the browser; RLS enforces isolation.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
# Secret key: server-side only, bypasses RLS. Never import this into a client component.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# --- OpenAI Realtime (tannlege voice demo on the marketing site) ---
# Copy this file to .env.local and fill in your own values.
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Resend (booking emails) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
