# ElevenLabs Conversational AI — required for the live voice demo.
# Copy this file to .env.local and fill in your own values.

# Your ElevenLabs API key (server-side only — never exposed to the browser).
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The Conversational AI agent ID you created in the ElevenLabs dashboard.
ELEVENLABS_AGENT_ID=agent_xxxxxxxxxxxxxxxxxxxxxxxx
